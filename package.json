{
  "name": "ctx-memory",
  "version": "1.0.2",
  "description": "Persistent memory layer for LLM coding agents (Claude Code, Codex, Gemini, OpenCode) — zero cloud, local SQLite + MCP",
  "type": "module",
  "keywords": [
    "llm",
    "memory",
    "mcp",
    "claude",
    "codex",
    "gemini",
    "opencode",
    "sqlite",
    "ai",
    "coding-agent"
  ],
  "author": "Ghadi Saab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GhadiSaab/llm-memory.git"
  },
  "homepage": "https://github.com/GhadiSaab/llm-memory#readme",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "ctx-memory": "./dist/src/cli/index.js"
  },
  "scripts": {
    "prepare": "tsc -p tsconfig.build.json",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "mcp": "node dist/src/mcp/index.js",
    "test:realworld": "node scripts/realworld-test.mjs",
    "test:realworld:verbose": "node scripts/realworld-test.mjs --verbose",
    "test:quality": "node scripts/quality-test.mjs",
    "test:quality:verbose": "node scripts/quality-test.mjs --verbose",
    "test:quality:real": "node scripts/quality-test.mjs --real"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^9.4.3",
    "sqlite-vec": "^0.1.7-alpha.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
